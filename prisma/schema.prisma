generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

model User {
    id               String    @id @default(cuid())
    email            String    @unique
    name             String?
    mobile           String?   @unique
    isMobileVerified Boolean   @default(false)
    image            String?
    password         String
    planType         String    @default("free")
    level            Int       @default(1)
    xp               Int       @default(0)
    coins            Int       @default(0)
    streak           Int       @default(0)
    bestStreak       Int       @default(0)
    totalStudyDays   Int       @default(0)
    lastActivityDate DateTime?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    // Relations
    answers         MCQAnswer[]
    progress        UserProgress[]
    bookmarks       Bookmark[]
    testSubmissions TestSubmission[]
}

model Plan {
    id            String   @id @default(cuid())
    name          String   @unique
    price         Int
    discountPrice Int?
    description   String?
    features      String[]
    isPopular     Boolean  @default(false)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
}

// ─── Exam Hierarchy ───────────────────────────────────────────────────────────

model Exam {
    id          String    @id @default(cuid())
    name        String    @unique
    description String?
    subjects    Subject[]
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
}

model Subject {
    id        String   @id @default(cuid())
    name      String
    icon      String?
    part      String   @default("A")
    sortOrder Int      @default(0)
    examId    String
    exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
    topics    Topic[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([name, examId])
}

model Topic {
    id        String @id @default(cuid())
    name      String
    subtopics String
    weight    String
    subjectId String
    sortOrder Int    @default(0)

    subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    mcqs      MCQ[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([name, subjectId])
}

model MCQ {
    id            String      @id @default(cuid())
    no            Int?
    question      String
    optionA       String
    optionB       String
    optionC       String
    optionD       String
    correctAnswer String
    explanation   String?
    difficulty    String      @default("Medium")
    isPyq         Boolean     @default(false)
    language      String      @default("English")
    translationId String?
    topicId       String
    topic         Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
    answers       MCQAnswer[]
    bookmarks     Bookmark[]
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt

    @@index([difficulty])
}

model MCQAnswer {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    mcqId     String
    mcq       MCQ      @relation(fields: [mcqId], references: [id], onDelete: Cascade)
    answer    String
    isCorrect Boolean
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, mcqId])
}

model UserProgress {
    id            String   @id @default(cuid())
    userId        String
    user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    subjectId     String
    correctCount  Int      @default(0)
    totalAttempts Int      @default(0)
    accuracy      Float    @default(0)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
}

model Admin {
    id        Int      @id @default(autoincrement())
    email     String   @unique
    password  String // bcrypt hash
    createdAt DateTime @default(now())
}

model PracticeMcq {
    id            String   @id @default(cuid())
    subject       String
    topic         String
    difficulty    String   @default("Medium")
    question      String
    optionA       String
    optionB       String
    optionC       String
    optionD       String
    correctAnswer String
    explanation   String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([subject, topic, difficulty])
    @@index([topic])
}

model MockTest {
    id              String             @id @default(cuid())
    title           String             @unique
    description     String?
    durationMinutes Int?
    csvFilename     String?
    totalQuestions  Int                @default(0)
    failedRows      Int                @default(0)
    uploadStatus    String             @default("draft")
    questions       MockTestQuestion[]
    createdAt       DateTime           @default(now())
    updatedAt       DateTime           @updatedAt
}

model MockTestQuestion {
    id            String   @id @default(cuid())
    mockTestId    String
    mockTest      MockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
    no            Int?
    question      String
    optionA       String
    optionB       String
    optionC       String
    optionD       String
    correctAnswer String
    explanation   String?
    difficulty    String   @default("Medium")
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([mockTestId])
}

model CSVUpload {
    id        Int      @id @default(autoincrement())
    filename  String
    questions Int
    failed    Int      @default(0)
    status    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Bookmark {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    mcqId     String
    mcq       MCQ      @relation(fields: [mcqId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, mcqId])
}

model TestSubmission {
    id          String   @id @default(cuid())
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    title       String
    mode        String
    totalMarks  Int
    earnedMarks Float
    percentage  Float
    details     Json?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model ContactMessage {
    id        String   @id @default(cuid())
    name      String
    email     String
    subject   String?
    message   String
    status    String   @default("UNREAD")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
