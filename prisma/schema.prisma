generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    password  String
    level     Int      @default(1)
    xp        Int      @default(0)
    coins     Int      @default(0)
    streak    Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    // Relations
    answers   MCQAnswer[]
    progress  UserProgress[]
}

model Plan {
    id          String   @id @default(cuid())
    name        String   @unique
    price       Int
    description String?
    features    String[]
    isPopular   Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model Syllabus {
    id        String   @id @default(cuid())
    name      String   @unique
    subjects  Subject[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Subject {
    id          String   @id @default(cuid())
    name        String
    icon        String?
    syllabusId  String
    syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
    topics      Topic[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@unique([name, syllabusId])
}

model Topic {
    id        String   @id @default(cuid())
    name      String
    subjectId String
    subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    mcqs      MCQ[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    @@unique([name, subjectId])
}

model MCQ {
    id            String   @id @default(cuid())
    question      String
    options       String[]
    correctAnswer String
    explanation   String?
    difficulty    String   @default("Medium")
    topicId       String
    topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
    answers       MCQAnswer[]
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
}

model MCQAnswer {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    mcqId     String
    mcq       MCQ      @relation(fields: [mcqId], references: [id], onDelete: Cascade)
    answer    String
    isCorrect Boolean
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    @@unique([userId, mcqId])
}

model UserProgress {
    id          String   @id @default(cuid())
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    subjectId   String
    correctCount Int    @default(0)
    totalAttempts Int   @default(0)
    accuracy    Float   @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}